{
  "schemaVersion": 1,
  "id": "mapart",
  "version": "${version}",
  "name": "Map Art",
  "description": "A Fabric mod for creating map art in Minecraft",
  "authors": [
    "bstar16"
  ],
  "contact": {
    "homepage": "https://example.com",
    "sources": "https://github.com/yourusername/mapart"
  },
  "license": "MIT",
  "icon": "assets/mapart/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.example.mapart.MapArtMod"
    ],
    "client": [
      "com.example.mapart.MapArtClientMod"
    ]
  },
  "mixins": [
    "mapart.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "minecraft": "1.21.11"
  }
